    {
      "parameters": {
        "promptType": "define",
        "text": "={{ JSON.stringify($json) }}",
        "messages": {
          "messageValues": [
            {
              "message": "=You are a data pipeline diagnostic agent. You will receive a record that failed schema validation, along with its specific validation errors. Classify the failure and respond with ONLY valid JSON, no markdown formatting, no explanation outside the JSON:\n\n{\n  \"failure_type\": \"fixable\" or \"needs_human_review\",\n  \"category\": \"date_format\" or \"missing_field\" or \"type_mismatch\" or \"ambiguous_data\" or \"other\",\n  \"suggested_fix\": \"<the corrected value, or null>\",\n  \"confidence\": <a number between 0.0 and 1.0>,\n  \"explanation\": \"<one sentence explaining the issue for a human log>\"\n}\n\nRules:\n- Only mark \"fixable\" if confidence > 0.85 AND the fix is unambiguous (e.g., converting \"14/03/2025\" to \"2025-03-14\" is safe).\n- NEVER mark something fixable if it requires guessing missing business data (e.g., a blank customer name, a negative price that could mean many things)."
            }
          ]
        },
        "batching": {}
      },
      "type": "@n8n/n8n-nodes-langchain.chainLlm",
      "typeVersion": 1.9,
      "position": [
        1232,
        80
      ],
      "id": "196a8e6f-e551-4baf-8ac3-20ad6819c289",
      "name": "Gemini Diagnosis Agent"
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const rawText = $json.text; // adjust field name if different — check your actual output field\nconst parsed = JSON.parse(rawText);\n\nreturn {\n  json: {\n    ...$('Route: Valid or Invalid').item.json, // pulls back the original row data\n    ...parsed // adds failure_type, category, suggested_fix, confidence, explanation\n  }\n};"
      },
