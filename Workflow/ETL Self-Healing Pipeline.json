        "jsCode": "const row = $input.item.json;\nconst errorField = row.validation_errors[0].field; // the field that failed\nconst fixedRow = { ...row };\n\nfixedRow[errorField] = row.suggested_fix; // apply the correction\nfixedRow.was_auto_fixed = true;\nfixedRow.fix_applied = `${errorField}: \"${row.validation_errors[0].raw_value}\" → \"${row.suggested_fix}\"`;\n\nreturn { json: fixedRow };"
      },
