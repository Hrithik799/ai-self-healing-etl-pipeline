    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\n// Count how many times each order_id appears\nconst idCounts = {};\nitems.forEach(item => {\n  const id = item.json.order_id;\n  idCounts[id] = (idCounts[id] || 0) + 1;\n});\n\nconst seenIds = new Set();\n\nreturn items.map(item => {\n  const row = { ...item.json };\n  const id = row.order_id;\n\n  if (idCounts[id] > 1) {\n    if (seenIds.has(id)) {\n      // This is a repeat occurrence — flag it as invalid\n      row.validation_errors = [\n        ...(row.validation_errors || []),\n        { field: \"order_id\", issue: \"duplicate_order_id\", raw_value: id }\n      ];\n      row.is_valid = false;\n    } else {\n      // First occurrence of this ID — mark as seen, leave as-is\n      seenIds.add(id);\n    }\n  }\n\n  return { json: row };\n});"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        816,
        -16
      ],
      "id": "25853fe0-80ac-447f-8d6d-4ac9ec9cc9ff",
      "name": "Duplicate detection"
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const row = $input.item.json;\nconst errors = [];\n\n// Check 1: customer_name must not be empty\nif (!row.customer_name || row.customer_name.trim() === \"\") {\n  errors.push({ field: \"customer_name\", issue: \"missing_field\" });\n}\n\n// Check 2: order_date must be ISO format (YYYY-MM-DD)\nconst isoDateRegex = /^\\d{4}-\\d{2}-\\d{2}$/;\nif (!isoDateRegex.test(String(row.order_date))) {\n  errors.push({ field: \"order_date\", issue: \"date_format\", raw_value: row.order_date });\n}\n\n// Check 3: quantity must be a valid number\nif (isNaN(Number(row.quantity))) {\n  errors.push({ field: \"quantity\", issue: \"type_mismatch\", raw_value: row.quantity });\n}\n\n// Check 4: unit_price must not be negative\nif (Number(row.unit_price) < 0) {\n  errors.push({ field: \"unit_price\", issue: \"ambiguous_data\", raw_value: row.unit_price });\n}\n\nreturn {\n  json: {\n    ...row,\n    is_valid: errors.length === 0,\n    validation_errors: errors\n  }\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
